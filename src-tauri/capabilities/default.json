{
  "$schema": "https://schema.tauri.app/config/2.0.0/capabilities",
  "identifier": "default",
  "description": "Default capabilities for the app",
  "windows": ["main"],
  "webviews": ["main"],
  "remote": {
    "urls": ["http://localhost:1420", "http://127.0.0.1:1420", "tauri://localhost"]
  },
  "permissions": [
    "core:default",
    "shell:allow-open",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save"
  ]
}